# EmailJS Configuration
# Copy this file to .env.local and fill in your actual values

# Get these from https://dashboard.emailjs.com/

# Service ID - from Email Services section
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here

# Template ID - from Email Templates section
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here

# Public Key (User ID) - from Account > General section
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here

# Note: All variables must start with NEXT_PUBLIC_ to be accessible in the browser
